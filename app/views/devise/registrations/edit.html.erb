<!-- app/views/devise/registrations/edit.html.erb -->
<!-- ユーザー編集ページ【設定(一覧)ページ】 -->

<!-- メインコンテンツ全体をアイボリー色の背景で表示、画面全体の高さを確保、中央配置 -->
<div class="bg-ivory min-h-screen flex items-center justify-center px-4 sm:px-6 py-6 sm:py-8">
  
  <!-- 中央に白いカードを配置、最大幅を設定、影を追加して立体感を出す -->
  <div class="bg-pure-white p-5 sm:p-7 md:p-8 max-w-2xl w-full rounded-2xl shadow-lg">
    
    <!-- ページタイトル -->
    <h2 class="text-xl sm:text-2xl md:text-3xl font-bold text-brand-navy text-center mb-6 sm:mb-8">
      設定(一覧)
    </h2>

    <!-- 全体のスペーシングを調整 -->
    <div class="space-y-6 sm:space-y-8">
      
      <!-- よく使う設定セクション -->
      <div class="bg-ivory p-5 sm:p-6 rounded-xl shadow-md">
        <!-- セクション見出し:トップ画面と同じスタイルに統一 -->
        <div class="mb-5 sm:mb-6 flex items-center">
          <div class="flex-1 border-t-2 border-brand-navy"></div>
          <h2 class="text-xl sm:text-2xl md:text-3xl font-bold text-brand-navy px-3 sm:px-5">
            よく使う設定
          </h2>
          <div class="flex-1 border-t-2 border-brand-navy"></div>
        </div>

        <!-- ボタン間の余白を広げる -->
        <div class="space-y-4 sm:space-y-5">
          <!-- 体重設定ボタン: edit_weight_setting_path（体重設定画面）に遷移 -->
          <%= link_to edit_weight_setting_path, class: "relative block w-full bg-brand-orange text-pure-white text-center py-4 sm:py-5 rounded-xl font-bold text-lg sm:text-xl shadow-lg hover:opacity-90 transition" do %>
            <!-- 体重アイコンを左側に配置 -->
            <svg xmlns="http://www.w3.org/2000/svg" class="absolute left-4 sm:left-5 top-1/2 -translate-y-1/2 w-6 h-6 sm:w-7 sm:h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3" />
            </svg>
            <span class="block">体重の変更</span>
          <% end %>
        
          <!-- メール通知時間設定ボタン: edit_notification_time_setting_path（通知時間設定画面）に遷移 -->
          <%= link_to edit_notification_time_setting_path, class: "relative block w-full bg-brand-orange text-pure-white text-center py-4 sm:py-5 rounded-xl font-bold text-lg sm:text-xl shadow-lg hover:opacity-90 transition" do %>
            <!-- 【修正】時計アイコンを左側に配置 -->
            <svg xmlns="http://www.w3.org/2000/svg" class="absolute left-4 sm:left-5 top-1/2 -translate-y-1/2 w-6 h-6 sm:w-7 sm:h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="block">メール通知時間の変更</span>
          <% end %>
        </div>
      </div>
    
      <!-- アカウント設定セクション -->
      <div class="bg-ivory p-5 sm:p-6 rounded-xl shadow-md">
        <!-- 【修正】セクション見出し:トップ画面と同じスタイルに統一 -->
        <div class="mb-5 sm:mb-6 flex items-center">
          <div class="flex-1 border-t-2 border-brand-navy"></div>
          <h2 class="text-xl sm:text-2xl md:text-3xl font-bold text-brand-navy px-3 sm:px-5">
            アカウント設定
          </h2>
          <div class="flex-1 border-t-2 border-brand-navy"></div>
        </div>
        
        <!-- パスワード変更ボタン: edit_password_setting_path（専用のパスワード変更画面）に遷移 -->
        <%= link_to edit_password_setting_path, class: "relative block w-full bg-brand-orange text-pure-white text-center py-4 sm:py-5 rounded-xl font-bold text-lg sm:text-xl shadow-lg hover:opacity-90 transition" do %>
          <!-- 【修正】鍵アイコンを左側に配置 -->
          <svg xmlns="http://www.w3.org/2000/svg" class="absolute left-4 sm:left-5 top-1/2 -translate-y-1/2 w-6 h-6 sm:w-7 sm:h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" />
          </svg>
          <span class="block">パスワードの変更</span>
        <% end %>
      </div>

      <!-- その他セクション -->
      <div class="bg-ivory p-5 sm:p-6 rounded-xl shadow-md">
        <!-- 【修正】セクション見出し:トップ画面と同じスタイルに統一 -->
        <div class="mb-5 sm:mb-6 flex items-center">
          <div class="flex-1 border-t-2 border-brand-navy"></div>
          <h2 class="text-xl sm:text-2xl md:text-3xl font-bold text-brand-navy px-3 sm:px-5">
            その他
          </h2>
          <div class="flex-1 border-t-2 border-brand-navy"></div>
        </div>

        <!-- ボタン間の余白を広げる -->
        <div class="space-y-4 sm:space-y-5">
          <!-- 【修正】お問い合わせボタン: contact_path（お問い合わせ画面）に遷移 -->
          <%= link_to contact_path, class: "relative block w-full bg-brand-orange text-pure-white text-center py-4 sm:py-5 rounded-xl font-bold text-lg sm:text-xl shadow-lg hover:opacity-90 transition" do %>
            <!-- メールアイコンを左側に配置 -->
            <svg xmlns="http://www.w3.org/2000/svg" class="absolute left-4 sm:left-5 top-1/2 -translate-y-1/2 w-6 h-6 sm:w-7 sm:h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <span class="block">お問い合わせ</span>
          <% end %>
        
          <!-- 利用規約ボタン: terms_path（利用規約画面）に遷移 -->
          <%= link_to terms_path, class: "relative block w-full bg-brand-orange text-pure-white text-center py-4 sm:py-5 rounded-xl font-bold text-lg sm:text-xl shadow-lg hover:opacity-90 transition" do %>
            <!-- ドキュメントアイコンを左側に配置 -->
            <svg xmlns="http://www.w3.org/2000/svg" class="absolute left-4 sm:left-5 top-1/2 -translate-y-1/2 w-6 h-6 sm:w-7 sm:h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            <span class="block">利用規約</span>
          <% end %>

          <!-- プライバシーポリシーボタン: privacy_path（プライバシーポリシー画面）に遷移 -->
          <%= link_to privacy_path, class: "relative block w-full bg-brand-orange text-pure-white text-center py-4 sm:py-5 rounded-xl font-bold text-lg sm:text-xl shadow-lg hover:opacity-90 transition" do %>
            <!-- シールドアイコンを左側に配置 -->
            <svg xmlns="http://www.w3.org/2000/svg" class="absolute left-4 sm:left-5 top-1/2 -translate-y-1/2 w-6 h-6 sm:w-7 sm:h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
            <span class="block">プライバシーポリシー</span>
          <% end %>
        </div>
      </div>
      
    </div>
  </div>
</div>
