<!-- app/views/static_pages/top.html.erb -->
<!-- ユーザーに見せるためのホーム画面のファイル -->

<!-- メインコンテンツ全体をアイボリー色の背景で表示、画面全体の高さを確保、中央配置 -->
<div class="bg-ivory min-h-screen flex items-center justify-center px-4 sm:px-6 py-6 sm:py-8">
  
  <!-- 中央に白いカードを配置、最大幅を設定、影を追加して立体感を出す -->
  <div class="bg-pure-white p-5 sm:p-7 md:p-8 max-w-2xl w-full rounded-2xl shadow-lg">
    
  <!-- メインタイトル「ミズモ」とロゴ: 横並び、中央配置、ネイビーの文字色 -->
  <div class="flex items-center justify-center mb-2 sm:mb-3">
    <%= image_tag "25292405.png", alt: "ミズモロゴ", class: "w-10 h-10 sm:w-16 sm:h-16 md:w-20 md:h-20 mr-3 sm:mr-4" %>
    <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold text-brand-navy">
      ミズモ
    </h1>
    <%= image_tag "25465676.png", alt: "ミズモロゴ", class: "w-10 h-10 sm:w-16 sm:h-16 md:w-20 md:h-20 ml-3 sm:ml-4" %>
  </div>
    
    <!-- サブタイトル「〜水分摂取を習慣化しよう〜」: タイトルより小さく、中央配置、ネイビーの文字色 -->
    <p class="text-base sm:text-lg md:text-xl text-brand-navy text-center mb-6 sm:mb-7 md:mb-8">
      〜簡単記録で水分摂取を習慣化しよう〜
    </p>
    
    <!-- 「使用方法」の見出し: 中央配置、太字、オレンジの文字色、左右に区切り線 -->
    <div class="mb-5 sm:mb-6 flex items-center">
      <div class="flex-1 border-t-2 border-brand-orange"></div>
      <h2 class="text-xl sm:text-2xl md:text-3xl font-bold text-brand-orange px-3 sm:px-5">
        ご使用方法
      </h2>
      <div class="flex-1 border-t-2 border-brand-orange"></div>
    </div>
    
    <!-- 使い方セクション全体を囲むdiv: 縦に並べる、ブロック間の余白を設定 -->
    <div class="space-y-4 sm:space-y-5">
      
      <!-- 設定方法のセクション -->
      <div class="bg-ivory p-4 sm:p-5 rounded-xl shadow-md">
        <!-- 小見出し: 中央配置、太字、ネイビーの文字色、大きめに -->
        <h3 class="text-lg sm:text-xl md:text-2xl font-bold text-brand-navy text-center mb-3 sm:mb-4">
          設定
        </h3>
        
        <!-- 設定項目①: 大きめの数字バッジ付き -->
        <div class="flex items-center mb-3">
          <span class="bg-brand-orange text-pure-white text-base sm:text-lg font-bold rounded-full w-9 h-9 sm:w-10 sm:h-10 flex items-center justify-center mr-3 flex-shrink-0">1</span>
          <p class="text-charcoal text-sm sm:text-base md:text-lg leading-relaxed">
            体重を入力します
          </p>
        </div>
        
        <!-- 設定項目②: 大きめの数字バッジ付き -->
        <div class="flex items-center">
          <span class="bg-brand-orange text-pure-white text-base sm:text-lg font-bold rounded-full w-9 h-9 sm:w-10 sm:h-10 flex items-center justify-center mr-3 flex-shrink-0">2</span>
          <p class="text-charcoal text-sm sm:text-base md:text-lg leading-relaxed">
            メール通知時間を設定します
          </p>
        </div>
      </div>
      
      <!-- 記録方法のセクション -->
      <div class="bg-ivory p-4 sm:p-5 rounded-xl shadow-md">
        <!-- 小見出し: 中央配置、太字、ネイビーの文字色、大きめに -->
        <h3 class="text-lg sm:text-xl md:text-2xl font-bold text-brand-navy text-center mb-3 sm:mb-4">
          記録
        </h3>

        <!-- 記録手順①: 大きめの数字バッジ付き -->
        <div class="flex items-start mb-3">
          <span class="bg-brand-orange text-pure-white text-base sm:text-lg font-bold rounded-full w-9 h-9 sm:w-10 sm:h-10 flex items-center justify-center mr-3 flex-shrink-0">1</span>
          <p class="text-charcoal text-sm sm:text-base md:text-lg leading-relaxed">
            メール通知後、メール内のURLを押します
          </p>
        </div>
        
        <!-- 記録手順②: 大きめの数字バッジとログインアイコン付き -->
        <div class="flex items-start mb-3">
          <span class="bg-brand-orange text-pure-white text-base sm:text-lg font-bold rounded-full w-9 h-9 sm:w-10 sm:h-10 flex items-center justify-center mr-3 flex-shrink-0">2</span>
          <div class="flex items-start">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 sm:h-6 sm:w-6 text-charcoal mr-2 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1" />
            </svg>
            <p class="text-charcoal text-sm sm:text-base md:text-lg leading-relaxed">
              ログインします
            </p>
          </div>
        </div>

        <!-- 記録手順③: 大きめの数字バッジと記録アイコン付き -->
        <div class="flex items-start">
          <span class="bg-brand-orange text-pure-white text-base sm:text-lg font-bold rounded-full w-9 h-9 sm:w-10 sm:h-10 flex items-center justify-center mr-3 flex-shrink-0">3</span>
          <div class="flex items-start">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 sm:h-6 sm:w-6 text-charcoal mr-2 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            <p class="text-charcoal text-sm sm:text-base md:text-lg leading-relaxed">
              飲水量に合わせて150〜250mlボタンを押します
            </p>
          </div>
        </div>
      </div>
      
      <!-- 確認方法のセクション -->
      <div class="bg-ivory p-4 sm:p-5 rounded-xl shadow-md">
        <!-- 小見出し: 中央配置、太字、ネイビーの文字色、大きめに -->
        <h3 class="text-lg sm:text-xl md:text-2xl font-bold text-brand-navy text-center mb-3 sm:mb-4">
          確認
        </h3>

        <!-- 確認手順①: 大きめの数字バッジとカレンダーアイコン付き -->
        <div class="flex items-start">
          <span class="bg-brand-orange text-pure-white text-base sm:text-lg font-bold rounded-full w-9 h-9 sm:w-10 sm:h-10 flex items-center justify-center mr-3 flex-shrink-0">1</span>
          <div class="flex items-start">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 sm:h-6 sm:w-6 text-charcoal mr-2 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <p class="text-charcoal text-sm sm:text-base md:text-lg leading-relaxed">
              毎日就寝前にカレンダーで達成状況を確認します
            </p>
          </div>
        </div>
      </div>
    </div>
    
    <!-- 注意書き -->
    <div class="bg-pure-white p-4 sm:p-5 rounded-lg mb-6 sm:mb-7 md:mb-8">
      <div class="flex items-start">
        <!-- 注意アイコン -->
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 sm:h-6 sm:w-6 text-brand-orange mr-2 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
        <div>
          <p class="text-sm sm:text-base text-gray-700 leading-relaxed">
            ※ 医学的根拠に基づいた水分摂取量を提案します<br>
            ※ 疾患や飲水制限がある方、体調に変化を感じた方は医師にご相談ください
          </p>
        </div>
      </div>
    </div>
    
    <!-- ここから「ご利用開始」セクション: ログイン前のみ表示 -->
    <% unless user_signed_in? %>
      <!-- 「ご利用開始」の見出し: 中央配置、太字、オレンジの文字色、左右に区切り線 -->
      <div class="mt-8 sm:mt-10 mb-5 sm:mb-6 flex items-center">
        <div class="flex-1 border-t-2 border-brand-orange"></div>
        <h2 class="text-xl sm:text-2xl md:text-3xl font-bold text-brand-orange px-3 sm:px-5">
          ご利用開始
        </h2>
        <div class="flex-1 border-t-2 border-brand-orange"></div>
      </div>
    
      <!-- アクションボタンエリア -->
      <div class="space-y-4">
        <!-- 新規登録ボタン(大) -->
        <%= link_to new_user_registration_path, class: "block w-full bg-brand-orange text-pure-white text-center py-4 sm:py-5 rounded-xl font-bold text-lg sm:text-xl shadow-lg hover:opacity-90 transition" do %>
          <span class="block">新規登録(無料)</span>
          <span class="block text-sm sm:text-base font-normal mt-1">初めての方</span>
        <% end %>
      
        <!-- ログインボタン(大) -->
        <%= link_to new_user_session_path, class: "block w-full bg-brand-navy text-pure-white text-center py-4 sm:py-5 rounded-xl font-bold text-lg sm:text-xl shadow-lg hover:opacity-90 transition" do %>
          <span class="block">ログイン</span>
          <span class="block text-sm sm:text-base font-normal mt-1">すでにアカウントをお持ちの方</span>
        <% end %>
      </div>
    <% end %>

  </div>
</div>
