<!-- app/views/devise/registrations/new.html.erb -->
<!-- 【修正】タイトルを i18n で日本語化 -->
<h2><%= t('.title') %></h2>

<!-- Deviseのユーザー登録フォームを開始 -->
<%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
  
  <!-- バリデーションエラーがあった場合にエラーメッセージを表示する部分 -->
  <%= render "devise/shared/error_messages", resource: resource %>

  <!-- メールアドレス入力欄のセクション -->
  <div class="field">
    <!-- 【修正】i18n でラベルを日本語化 -->
    <p><%= f.label :email %></p>
    <!-- メールアドレスを入力するテキストボックスを表示（自動フォーカス、自動補完有効） -->
    <p><%= f.email_field :email, autofocus: true, autocomplete: "email" %></p>
  </div>

  <!-- パスワード入力欄のセクション -->
  <div class="field">
    <!-- 【修正】i18n でラベルを日本語化 -->
    <p><%= f.label :password %></p>
    <!-- パスワードの最小文字数が設定されている場合のみ実行 -->
    <% if @minimum_password_length %>
      <!-- 【修正】「(8 characters minimum)」から「(8文字以上)」に変更 -->
      <p><em>(<%= @minimum_password_length %>文字以上)</em></p>
    <% end %>
    <!-- パスワードを入力するテキストボックスを表示（入力内容は隠される） -->
    <p><%= f.password_field :password, autocomplete: "new-password" %></p>
  </div>

  <!-- パスワード確認入力欄のセクション -->
  <div class="field">
    <!-- 【修正】i18n でラベルを日本語化 -->
    <p><%= f.label :password_confirmation %></p>
    <!-- パスワード確認用のテキストボックスを表示（入力内容は隠される） -->
    <p><%= f.password_field :password_confirmation, autocomplete: "new-password" %></p>
  </div>

  <!-- 【追加】体重入力欄のセクション -->
  <div class="field">
    <!-- 【修正】i18n でラベルを日本語化 -->
    <p><%= f.label :weight %></p>
    <!-- 体重を入力する数値入力欄を表示（0.1刻みで入力可能） -->
    <p><%= f.number_field :weight, step: 0.1 %></p>
  </div>

  <!-- 【修正】登録ボタンのセクション -->
  <div class="actions">
    <!-- 【修正】登録ボタンのラベルを i18n で日本語化 -->
    <%= f.submit t('.sign_up') %>
  </div>
  
<!-- フォームの終了 -->
<% end %>

<!-- ログインページへのリンクなどを表示 -->
<%= render "devise/shared/links" %>
