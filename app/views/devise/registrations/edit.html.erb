<!-- app/views/devise/registrations/edit.html.erb -->
<!-- ユーザー編集ページ（設定ページ） -->

<!-- メイン部分 -->
<main class="main-content">
  <!-- タイトル -->
  <h2 class="main-title">設定</h2>
  
  <!-- 説明文 -->
  <p class="description">
    パスワードを変更したい方は現在と新しいパスワードを入力してください。<br>
    体重のみ変更する方は体重のみ入力してください。
  </p>
  
  <!-- フォーム -->
  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: 'edit-form' }) do |f| %>
    
    <!-- エラーメッセージ表示エリア -->
    <%= render "devise/shared/error_messages", resource: resource %>
    
    <!-- 現在のパスワード入力欄 -->
    <div class="form-group">
      <!-- ラベル -->
      <%= f.label :current_password, '現在のパスワード', class: 'form-label' %>
      <!-- 入力欄 -->
      <%= f.password_field :current_password, autocomplete: "current-password", class: 'form-control' %>
    </div>
    
    <!-- 新しいパスワード入力欄 -->
    <div class="form-group">
      <!-- ラベル -->
      <%= f.label :password, '新しいパスワード（8文字以上）', class: 'form-label' %>
      <!-- 入力欄 -->
      <%= f.password_field :password, autocomplete: "new-password", placeholder: "変更しない場合は空欄", class: 'form-control' %>
    </div>
    
    <!-- 新しいパスワード確認入力欄 -->
    <div class="form-group">
      <!-- ラベル -->
      <%= f.label :password_confirmation, '新しいパスワード（確認用）', class: 'form-label' %>
      <!-- 入力欄 -->
      <%= f.password_field :password_confirmation, autocomplete: "new-password", class: 'form-control' %>
    </div>
    
    <!-- 【修正】体重入力欄にエラーメッセージ表示を追加 -->
    <div class="form-group">
      <!-- ラベル -->
      <%= f.label :weight, '体重 (kg)', class: 'form-label' %>
      <!-- 入力欄 -->
      <%= f.number_field :weight, step: 0.1, min: 0, class: 'form-control' %>
      
      <!-- 【追加】体重のエラーメッセージを個別に表示 -->
      <% if resource.errors[:weight].any? %>
        <div class="text-danger mt-2">
          <%= resource.errors[:weight].join(', ') %>
        </div>
      <% end %>
    </div>
    
    <!-- ボタンエリア -->
    <div class="form-actions d-flex justify-content-between">
      <!-- 保存ボタン -->
      <%= f.submit '保存', class: 'btn btn-primary' %>
      
      <!-- キャンセルボタン（記録画面へ遷移） -->
      <%= link_to 'キャンセル', water_intakes_path, class: 'btn btn-secondary' %>
    </div>
    
  <% end %>
  
</main>