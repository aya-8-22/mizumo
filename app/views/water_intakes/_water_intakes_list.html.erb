<%# app/views/water_intakes/_water_intakes_list.html.erb %>
<%# 水分記録をカレンダー形式で表示する部分テンプレート %>
<%# water_intakes: 表示する記録のコレクション(配列) %>

<div class="container mt-4">
  <%# カレンダーのタイトル %>
  <h3 class="mb-4">💧 水分記録カレンダー</h3>
  
  <%# テーブル全体を囲むカード %>
  <div class="card">
    <div class="card-body">
      <%# 記録を表示するテーブル %>
      <table class="table table-bordered text-center">
        <%# テーブルのヘッダー部分 %>
        <thead class="table-light">
          <tr>
            <%# 日付列のヘッダー %>
            <th style="width: 150px;">日付</th>
            
            <%# 8時の列のヘッダー %>
            <th style="width: 120px;">8時</th>
            
            <%# 12時の列のヘッダー %>
            <th style="width: 120px;">12時</th>
            
            <%# 17時の列のヘッダー %>
            <th style="width: 120px;">17時</th>
          </tr>
        </thead>
        
        <%# テーブルの本体部分 %>
        <tbody>
          <%# 過去7日分の日付を作成(今日から7日前まで) %>
          <% (0..6).each do |days_ago| %>
            <%# 表示する日付を計算(今日から days_ago 日前) %>
            <% date = Date.today - days_ago.days %>
            
            <%# その日の記録を取得 %>
            <% day_intakes = water_intakes.select { |intake| intake.recorded_at.to_date == date } %>
            
            <%# 1日分の行を作成 %>
            <tr>
              <%# 日付を表示する列(例: 1/24) %>
              <td class="align-middle">
                <%= date.strftime('%-m/%-d') %>
              </td>
              
              <%# 8時の記録を表示する列 %>
              <td class="align-middle">
                <%# その日の8時の記録を探す %>
                <% intake_8 = day_intakes.find { |i| i.time_slot == 8 } %>
                
                <%# 記録があるかチェック %>
                <% if intake_8 %>
                  <%# 記録がある場合: 青いボタンで「飲んだ」と表示 %>
                  <button class="btn btn-primary btn-sm" disabled>
                    200ml<br>
                    <small>飲んだ</small>
                  </button>
                <% else %>
                  <%# 記録がない場合: 白いボタンで「飲んでない」と表示 %>
                  <button class="btn btn-outline-secondary btn-sm" disabled>
                    200ml<br>
                    <small>飲んでない</small>
                  </button>
                <% end %>
              </td>
              
              <%# 12時の記録を表示する列 %>
              <td class="align-middle">
                <%# その日の12時の記録を探す %>
                <% intake_12 = day_intakes.find { |i| i.time_slot == 12 } %>
                
                <%# 記録があるかチェック %>
                <% if intake_12 %>
                  <%# 記録がある場合: 青いボタンで「飲んだ」と表示 %>
                  <button class="btn btn-primary btn-sm" disabled>
                    200ml<br>
                    <small>飲んだ</small>
                  </button>
                <% else %>
                  <%# 記録がない場合: 白いボタンで「飲んでない」と表示 %>
                  <button class="btn btn-outline-secondary btn-sm" disabled>
                    200ml<br>
                    <small>飲んでない</small>
                  </button>
                <% end %>
              </td>
              
              <%# 17時の記録を表示する列 %>
              <td class="align-middle">
                <%# その日の17時の記録を探す %>
                <% intake_17 = day_intakes.find { |i| i.time_slot == 17 } %>
                
                <%# 記録があるかチェック %>
                <% if intake_17 %>
                  <%# 記録がある場合: 青いボタンで「飲んだ」と表示 %>
                  <button class="btn btn-primary btn-sm" disabled>
                    200ml<br>
                    <small>飲んだ</small>
                  </button>
                <% else %>
                  <%# 記録がない場合: 白いボタンで「飲んでない」と表示 %>
                  <button class="btn btn-outline-secondary btn-sm" disabled>
                    200ml<br>
                    <small>飲んでない</small>
                  </button>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
      
      <%# 説明文 %>
      <div class="mt-3">
        <p class="text-muted mb-0">
          <small>
            💡 青いボタン: その時間に水を飲んだ記録<br>
            💡 白いボタン: その時間に記録なし
          </small>
        </p>
      </div>
    </div>
  </div>
</div>