<!-- メイン画面(フレックスボックス、中央揃え、最小高さ、背景色、上の余白を設定) -->
<main class="flex justify-center items-start min-h-screen bg-ivory pt-10">
  <!-- ログインフォームのコンテナ(背景色、余白、角丸、影、最大幅を設定) -->
  <div class="bg-pure-white p-10 rounded-lg shadow-md max-w-[500px] w-full">
    <!-- タイトル(中央揃え、下の余白、文字色、文字サイズ、太字を設定) -->
    <h2 class="text-center mb-8 text-charcoal text-3xl font-bold">ログイン</h2>

    <!-- フラッシュメッセージ(成功)を表示 -->
    <% if flash[:notice] %>
      <!-- 成功メッセージのボックス(緑色の背景、枠線、文字色、余白、角丸を設定) -->
      <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative mb-4" role="alert">
        <%= flash[:notice] %>
      </div>
    <% end %>

    <!-- Deviseのログインフォームを開始 -->
    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      
      <!-- メールアドレス入力欄(下の余白、相対位置を設定) -->
      <div class="mb-5 relative">
        <!-- ラベル(ブロック要素、下の余白、文字色、太字を設定) -->
        <%= f.label :email, "メールアドレス", class: "block mb-2 text-charcoal font-bold" %>
        <!-- 入力欄のラッパー(アイコンと入力欄を囲む、相対位置を設定) -->
        <div class="relative">
          <!-- メールアイコン(位置、サイズ、色を設定) -->
          <svg xmlns="http://www.w3.org/2000/svg" class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-charcoal pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          <!-- メールアドレス入力フィールド(幅、余白、枠線、角丸、文字サイズ、文字色、背景色、トランジション、最小高さ、フォーカス時の枠線色を設定) -->
          <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full py-4 px-3 pl-11 border border-charcoal rounded-lg text-base text-charcoal bg-pure-white transition-colors duration-300 min-h-[55px] focus:outline-none focus:border-brand-orange", placeholder: " " %>
        </div>
      </div>

      <!-- パスワード入力欄(下の余白、相対位置を設定) -->
      <div class="mb-5 relative">
        <!-- ラベル(ブロック要素、下の余白、文字色、太字を設定) -->
        <%= f.label :password, "パスワード", class: "block mb-2 text-charcoal font-bold" %>
        <!-- 入力欄のラッパー(アイコンと入力欄を囲む、相対位置を設定) -->
        <div class="relative">
          <!-- 鍵アイコン(位置、サイズ、色を設定) -->
          <svg xmlns="http://www.w3.org/2000/svg" class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-charcoal pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
          </svg>
          <!-- パスワード入力フィールド(幅、余白、枠線、角丸、文字サイズ、文字色、背景色、トランジション、最小高さ、フォーカス時の枠線色を設定) -->
          <%= f.password_field :password, autocomplete: "current-password", class: "w-full py-4 px-3 pl-11 border border-charcoal rounded-lg text-base text-charcoal bg-pure-white transition-colors duration-300 min-h-[55px] focus:outline-none focus:border-brand-orange", placeholder: " " %>
        </div>
      </div>

      <!-- パスワード表示チェックボックス(下の余白、フレックスボックス、縦方向の中央揃えを設定) -->
      <div class="mb-4 flex items-center">
        <!-- チェックボックス(右の余白、幅、高さ、カーソルを設定) -->
        <input type="checkbox" id="show-password" class="mr-2 w-[18px] h-[18px] cursor-pointer">
        <!-- チェックボックスのラベル(文字色、文字サイズ、カーソルを設定) -->
        <label for="show-password" class="text-charcoal text-sm cursor-pointer">パスワードを表示する</label>
      </div>

      <!-- ログインボタン(上の余白、中央揃えを設定) -->
      <div class="mt-8 text-center">
        <!-- ログインボタン(幅、余白、背景色、文字色、枠線なし、角丸、文字サイズ、太字、トランジションを設定、初期状態はグレー) -->
        <%= f.submit "ログイン", class: "w-full py-3.5 bg-gray-400 text-pure-white border-none rounded-lg text-base font-bold transition-colors duration-300", id: "login-button" %>
      </div>

      <!-- パスワードを忘れた場合のリンク(コメントアウト中) -->
      <!-- <div class="mt-4 text-center"> -->
        <!-- <%= link_to "パスワードを忘れた場合", new_password_path(resource_name), class: "text-charcoal text-sm underline transition-colors duration-300 hover:text-brand-orange" %> -->
      <!-- </div> -->

      <!-- 新規登録ページへのリンク(コメントアウト中) -->
      <!-- <div class="mt-4 text-center"> -->
        <!-- <span class="text-charcoal text-sm">アカウントをお持ちでない方は</span> -->
        <!-- <%= link_to "新規登録", new_registration_path(resource_name), class: "text-charcoal text-sm underline transition-colors duration-300 hover:text-brand-orange" %> -->
      <!-- </div> -->
    <% end %>
  </div>
</main>

