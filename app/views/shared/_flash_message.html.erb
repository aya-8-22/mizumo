<!-- app/views/shared/_flash_message.html.erb -->
<!-- フラッシュメッセージを表示するパーシャルファイル -->
<!-- メッセージをどのように表示するかを記述 HTMLのタグや構造を定義 レイアウトを担当 -->

<!-- flash の中身を1つずつ取り出すループ開始 -->
<!-- message_type: メッセージの種類（例: 'notice', 'alert'） -->
<!-- message: メッセージの本文（例: 'ログインしました'） -->
<% flash.each do |message_type, message| %>
  <!-- 【修正】data-controller="flash" を追加して Stimulus コントローラーと紐付け -->
  <!-- 【修正】data-flash-target="message" を追加して JavaScript から要素を取得できるようにする -->
  <!-- メッセージを表示する div タグ（Bootstrap のスタイルを適用） -->
  <!-- bootstrap_class_for メソッドで message_type を Bootstrap のクラス名に変換 -->
  <!-- 例: 'notice' → 'success' → 'alert-success'（緑色） -->
  <div class="alert alert-<%= bootstrap_class_for(message_type) %>" data-controller="flash" data-flash-target="message">
    <!-- メッセージ本文を表示 -->
    <%= message %>
  </div>
<% end %>