<!-- app/views/devise/shared/_links.html.erb -->

<!-- ログインページへのリンク（ログインページ以外で表示） -->
<%- if controller_name != 'sessions' %>
  <!-- ログインページへのリンクを表示 -->
  <p><%= link_to "Log in", new_session_path(resource_name) %></p>
<% end %>

<!-- 【修正】新規登録ページへのリンク（ログインページでは表示しない） -->
<%- if devise_mapping.registerable? && controller_name != 'registrations' && controller_name != 'sessions' %>
  <!-- 【修正】ログインページでは表示しない -->
  <p><%= link_to "Sign up", new_registration_path(resource_name) %></p>
<% end %>

<!-- 【修正】パスワード再設定ページへのリンク（ログインページでは表示しない） -->
<%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' && controller_name != 'sessions' %>
  <!-- 【修正】ログインページでは表示しない -->
  <p><%= link_to "Forgot your password?", new_password_path(resource_name) %></p>
<% end %>

<!-- メールアドレス確認ページへのリンク（確認メール再送ページ以外で表示） -->
<%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
  <!-- メールアドレス確認ページへのリンクを表示 -->
  <p><%= link_to "Didn't receive confirmation instructions?", new_confirmation_path(resource_name) %></p>
<% end %>

<!-- アカウントロック解除ページへのリンク（アカウントロック解除ページ以外で表示） -->
<%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
  <!-- アカウントロック解除ページへのリンクを表示 -->
  <p><%= link_to "Didn't receive unlock instructions?", new_unlock_path(resource_name) %></p>
<% end %>

<!-- OmniAuth 認証へのリンク（設定されている場合のみ表示） -->
<%- if devise_mapping.omniauthable? %>
  <!-- OmniAuth 認証プロバイダーごとにリンクを表示 -->
  <%- resource_class.omniauth_providers.each do |provider| %>
    <!-- OmniAuth 認証へのリンクを表示 -->
    <p><%= button_to "Sign in with #{OmniAuth::Utils.camelize(provider)}", omniauth_authorize_path(resource_name, provider), data: { turbo: false } %></p>
  <% end %>
<% end %>
