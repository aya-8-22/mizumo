<!-- app/views/layouts/application.html.erb -->
<!-- アプリケーション全体で共通して表示される部分（ヘッダー、フッター、サイドバーなど） -->
<!DOCTYPE html>
<html>
  <head>
    <!-- ページタイトルを設定 -->
    <title>ミズモ</title>
    <!-- レスポンシブ対応のためのビューポート設定 -->
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <!-- CSRF トークンを埋め込む（セキュリティ対策） -->
    <%= csrf_meta_tags %>
    <!-- Content Security Policy を設定（セキュリティ対策） -->
    <%= csp_meta_tag %>

    <!-- CSS ファイルを読み込む -->
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <!-- JavaScript ファイルを読み込む -->
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <!-- 【追加】ヘッダーを表示（app/views/shared/_header.html.erb を読み込む） -->
    <%= render 'shared/header' %>
    
    <!-- 【追加】Devise のフラッシュメッセージ（notice）を表示 -->
    <% if notice %>
      <p class="notice"><%= notice %></p>
    <% end %>
    <!-- 【追加】Devise のフラッシュメッセージ（alert）を表示 -->
    <% if alert %>
      <p class="alert"><%= alert %></p>
    <% end %>
    
    <!-- 各ページの内容を表示（各コントローラーのビューが挿入される） -->
    <%= yield %>
  </body>
</html>
